# Configurações do Redis (Railway ou Local)
REDIS_URL="redis://localhost:6379"

# Configurações de Ambiente
NODE_ENV="development"
PORT=4321
HOST="0.0.0.0"
DATABASE_URL="postgresql://user:password@host:port/dbname"
PUBLIC_SHOW_SOCIAL_PROOF="false"
PUBLIC_SHOW_COUNTDOWN_TIMER="false"

# Configurações do WhatsApp Gateway (neo-whatsapp-connect)
WHATSAPP_WEBHOOK_SECRET="seu_webhook_secret_aqui"
WHATSAPP_GATEWAY_URL="https://seu-gateway.up.railway.app"
WHATSAPP_GATEWAY_SECRET="seu_gateway_secret_aqui"

# Configurações da Bella (Azure OpenAI)
AZURE_OPENAI_ENDPOINT="seu_endpoint_azure_aqui"
AZURE_OPENAI_API_KEY="sua_chave_api_aqui"
AZURE_OPENAI_API_VERSION="2025-01-01-preview"
AZURE_OPENAI_DEPLOYMENT_NAME="gpt-4o"
BELLA_MODEL="gpt-4o"
BELLA_MAX_TOKENS="800"
BELLA_TEMPERATURE="0.7"

# Google Tag (gtag.js) — Google Ads
PUBLIC_GTAG_ID="AW-18004058795"

# Meta Pixel — dataset "Embelleze Trindade Web"
# ID: 1879889489292663 — criado em 2026-05-21 na ad account 1200874380843545
# Conversions API ativada — configurar server-side para PIX_PAGO depois
PUBLIC_META_PIXEL_ID="1879889489292663"

# Google Maps API Key — necessária para embed no /mapa
PUBLIC_GOOGLE_MAPS_KEY="pendente"

# Probeltec CRM
PROBELTEC_API_URL="https://api.probeltec.com/api/v1"
PROBELTEC_AUTH_URL="https://api-auth.probeltec.com/v1"
PROBELTEC_EMAIL="email@institutoembelleze.com"
PROBELTEC_PASSWORD="sua_senha_aqui"
# idOrigin padrão para leads WhatsApp Bella = 7 (Instagram WhatsApp)
PROBELTEC_DEFAULT_ORIGIN_ID="7"
PROBELTEC_DEFAULT_ORIGIN_NAME="Instagram WhatsApp"
# idFunnel padrão = 1 (SDR)
PROBELTEC_DEFAULT_FUNNEL_ID="1"

# ── FlowPay Gateway ────────────────────────────────────────────────────────
# Bearer token enviado pelo FlowPay no header Authorization dos webhooks.
# Configurar no painel FlowPay: Settings > Webhooks > Secret Token
# URL do webhook: https://embelleze-bella.online/api/payment/flowpay/webhook
FLOWPAY_WEBHOOK_SECRET="seu_secret_aqui"

# ── Resend — Email transacional ─────────────────────────────────────────────
# Remetente: andreia@embelleze-bella.online (SPF+DKIM+DNSSEC configurados)
# SDK ainda não instalado — pnpm add resend --filter embelleze-web quando implementar
RESEND_API_KEY="re_seu_token_aqui"
# Segredo Bearer para POST /api/followup/email-dispatch
FOLLOWUP_DISPATCH_SECRET="seu_secret_dispatch_aqui"
# Caminhos locais no runtime (opcionais)
EMAIL_DISPATCH_QUEUE_PATH="/app/data/email-dispatch-queue.json"
FOLLOWUP_EVENTS_PATH="/app/data/followup-events.jsonl"
# Segredo Bearer do webhook de eventos Resend -> /api/followup/resend-webhook
RESEND_WEBHOOK_SECRET="seu_secret_webhook_resend_aqui"

# ── Meta Conversions API (CAPI) ─────────────────────────────────────────────
# Token server-side para evento Purchase após PIX_PAGO confirmado
# Gerar em: Meta Business Suite → Eventos → Configurações → CAPI → Gerar token
# Pixel: 1879889489292663 — implementar em api/payment/flowpay/webhook.ts
CAPI_ACCESS_TOKEN="seu_token_capi_aqui"
